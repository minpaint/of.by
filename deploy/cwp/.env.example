# Скопировать в /home/django/webapps/ofby/.env и заполнить

SECRET_KEY=замените-на-случайную-строку-50+-символов

# База данных
OF_BY_DB_PATH=/home/django/webapps/ofby/db.sqlite3

# Кэш (директория на сервере)
OF_BY_CACHE_DIR=/home/django/webapps/ofby/cache

# Gunicorn
GUNICORN_WORKERS=4
GUNICORN_BIND=127.0.0.1:8021
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info
